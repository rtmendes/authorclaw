{
  "server": {
    "port": 3847,
    "host": "127.0.0.1"
  },
  "security": {
    "permissionPreset": "standard",
    "requireAuth": true
  },
  "ai": {
    "preferredProvider": null,
    "maxHistoryMessages": 20,
    "defaultTemperature": 0.7,
    "ollama": {
      "enabled": true,
      "endpoint": "http://localhost:11434",
      "model": "llama3.2"
    },
    "gemini": {
      "model": "gemini-2.5-flash"
    },
    "deepseek": {
      "model": "deepseek-chat"
    },
    "claude": {
      "model": "claude-sonnet-4-5-20250929"
    },
    "openai": {
      "model": "gpt-4o"
    },
    "openrouter": {
      "model": "anthropic/claude-sonnet-4-5"
    }
  },
  "memory": {
    "maxConversationHistory": 50,
    "maxMemoryEntries": 200,
    "autoSummarize": true
  },
  "branding": {
    "footerLinks": {
      "website":  "https://www.getwritingsecrets.com",
      "youtube":  "https://www.youtube.com/@WritingSecrets",
      "substack": "https://writingsecrets.substack.com",
      "kofi":     "https://ko-fi.com/writingsecrets/shop"
    }
  },
  "heartbeat": {
    "intervalMinutes": 15,
    "dailyWordGoal": 1000,
    "enableReminders": true,
    "quietHoursStart": 0,
    "quietHoursEnd": 0
  },
  "costs": {
    "dailyLimit": 5,
    "monthlyLimit": 50,
    "alertAt": 0.8
  },
  "bridges": {
    "telegram": {
      "enabled": false,
      "allowedUsers": [],
      "pairingEnabled": true
    },
    "discord": {
      "enabled": false
    }
  }
}
